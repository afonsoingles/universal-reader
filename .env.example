# Inventory connection
INVENTORY_WS_URL=ws://192.168.1.100:8000/ws/reader
INVENTORY_API_KEY=your-secret-key-here

# Dashboard
DASHBOARD_PASSWORD=dashboard-password
DASHBOARD_PORT=5050

# Hardware — all GPIO pins configurable
LCD_I2C_ADDR=0x27
BUZZER_PIN=18
RC522_MISO=9
RC522_MOSI=10
RC522_SCK=11
RC522_SDA=8
RC522_RST=25
